{
    "workbench.colorTheme": "Oceanic Plus",
    "git.confirmSync": false,
    "markdown-preview-github-styles.colorTheme": "light",
    "workbench.colorCustomizations": {
        "peekViewEditor.matchHighlightBackground": "#e2934991",
        "[One Dark Pro]": {
            "editor.selectionHighlightBorder": "#333b3f",
            "editor.selectionHighlightBackground": "#333b3f",
            "editor.background": "#282C34"
        },
        "[Atom One Dark]": {
            "activityBar.background": "#21252b"
        },
        "[Oceanic Next]": {
            "statusBar.background": "#252526",
            "titleBar.activeBackground": "#252526",
            "activityBar.background": "#252526"
        }
    },
    "[javascript]": {
        "editor.tabSize": 2
    },
    "[go]": {
        "editor.formatOnSave": true
    },
    "files.watcherExclude": {
        "**/.git/objects/**": true,
        "**/.git/subtree-cache/**": true,
        "**/node_modules/**": true
    },
    "workbench.editor.enablePreview": false,
    "workbench.editor.enablePreviewFromQuickOpen": false,
    "explorer.openEditors.visible": 0,
    "javascript.updateImportsOnFileMove.enabled": "always",
    "editor.formatOnSave": true,
    "gitlens.codeLens.enabled": false,
    "gitlens.mode.statusBar.enabled": false,
    "gitlens.statusBar.enabled": false,
    "breadcrumbs.enabled": true,
    "git.autofetch": true,
    "editor.suggestSelection": "first",
    "editor.multiCursorModifier": "ctrlCmd",
    "files.associations": {
        "*mdx": "markdown"
    },
    "liveshare.featureSet": "insiders",
    "git.openRepositoryInParentFolders": "always",
    "pylint.args": [
        "--disable=W1309,C0209,C0116",
    ],
    "security.workspace.trust.untrustedFiles": "open",
    "telemetry.telemetryLevel": "off",
    "markdownlint.config": {
        "MD029": false
    },
    "js/ts.updateImportsOnFileMove.enabled": "always",
    "gitlens.ai.model": "vscode",
    "gitlens.ai.vscode.model": "copilot:gpt-4.1",
    "markdown-mermaid.darkModeTheme": "base",
    "theme-by-language.themes": {
        "*": "Oceanic Plus",
        "skill": "GitHub Light Default",
        "markdown": "Atom One Light"
    }
}
